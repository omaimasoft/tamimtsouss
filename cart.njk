---
layout: base.njk
title: سلة المشتريات
css:
  - /assets/css/cart.css
---

<section class="cart-page">

  <h1 class="cart-title">سلة المشتريات</h1>

  <div class="cart-layout">

    <!-- المنتجات -->
    <div class="cart-items" id="cart-items"></div>

    <!-- ملخص الطلب -->
    <aside class="cart-summary">

      <h3>ملخص الطلب</h3>

      <div class="summary-line">
        <span>المجموع الفرعي</span>
        <strong><span id="cart-subtotal">0</span> درهم</strong>
      </div>

      <div class="summary-line">
        <span>التوصيل</span>
        <strong><span id="shipping-cost">0</span> درهم</strong>
      </div>

      <div class="summary-line total">
        <span>الإجمالي</span>
        <strong><span id="cart-total">0</span> درهم</strong>
      </div>

      <button class="whatsapp-btn" onclick="confirmOrder()">
        اطلب عبر واتساب
      </button>

      <button class="danger-btn" onclick="clearCart()">
        تفريغ السلة
      </button>

    </aside>

  </div>

</section>

<script>
/* ✅ رقم واتساب (أرقام فقط) */
const WHATSAPP_PHONE = "212763538294"; // <-- بدّلي هنا

window.confirmOrder = function () {
  const cart = getCart();
  if (!cart || cart.length === 0) {
    alert("السلة فارغة حالياً");
    return;
  }

  // ✅ نحسب المجموع ونبني الرسالة
  let total = 0;
  let lines = ["🛒 طلب جديد من الموقع:"];

  cart.forEach(item => {
    const itemTotal = Number(item.price) * Number(item.qty);
    total += itemTotal;
    lines.push(`• ${item.name} × ${item.qty} = ${itemTotal} درهم`);
  });

  // التوصيل نفس القاعدة اللي عندك
  const shipping = total >= 600 ? 0 : 40;
  const finalTotal = total + shipping;

  lines.push("");
  lines.push(`المجموع الفرعي: ${total} درهم`);
  lines.push(`التوصيل: ${shipping} درهم`);
  lines.push(`الإجمالي: ${finalTotal} درهم`);

  const text = encodeURIComponent(lines.join("\n"));

  // ✅ أفضل رابط (ما فيهش + ولا -)
  const url = `https://wa.me/${WHATSAPP_PHONE}?text=${text}`;
  window.open(url, "_blank", "noopener,noreferrer");
};
</script>