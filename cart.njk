---
layout: base.njk
title: سلة المشتريات
css:
  - /assets/css/cart.css
---

<section class="cart-page">
  <h1 class="cart-title">سلة المشتريات</h1>

  <div class="cart-layout">
    <!-- المنتجات -->
    <div class="cart-items" id="cart-items"></div>

    <!-- ملخص الطلب -->
    <aside class="cart-summary">
      <h3>ملخص الطلب</h3>

      <div class="summary-line">
        <span>المجموع الفرعي</span>
        <strong><span id="cart-subtotal">0</span> درهم</strong>
      </div>

      <div class="summary-line">
        <span>التوصيل</span>
        <strong><span id="shipping-cost">0</span> درهم</strong>
      </div>

      <div class="summary-line total">
        <span>الإجمالي</span>
        <strong><span id="cart-total">0</span> درهم</strong>
      </div>

      <button class="whatsapp-btn" onclick="confirmOrder()">
        اطلب عبر واتساب
      </button>

      <button class="danger-btn" onclick="clearCart()">
        تفريغ السلة
      </button>
    </aside>
  </div>
</section>

<script>
/**
 * ✅ مهم: خلي الرقم هنا "نقي" فقط أرقام
 * مثال المغرب: 2126xxxxxxxx أو 2127xxxxxxxx
 */
const WHATSAPP_PHONE = "212763538294"; // <-- بدّلي هذا

// نخلي الدالة Global بشكل صريح
window.confirmOrder = function () {
  const cart = (typeof getCart === "function") ? getCart() : [];

  if (!cart || cart.length === 0) {
    alert("السلة فارغة");
    return;
  }

  // نبني الرسالة
  let lines = ["🛒 طلب جديد من الموقع:"];
  let total = 0;

  cart.forEach(item => {
    const qty = Number(item.qty || 0);
    const price = Number(item.price || 0);
    const itemTotal = price * qty;
    total += itemTotal;

    lines.push(`• ${item.name} × ${qty} = ${itemTotal} درهم`);
  });

  lines.push("");
  lines.push(`المجموع: ${total} درهم`);

  const text = encodeURIComponent(lines.join("\n"));

  // ✅ هذا الرابط هو الأكثر استقراراً
  const url = `https://wa.me/${WHATSAPP_PHONE}?text=${text}`;

  // ✅ للتأكد شنو الرقم اللي فعلاً كيتستعمل
  console.log("WhatsApp URL:", url);

  window.open(url, "_blank", "noopener,noreferrer");
};
</script>