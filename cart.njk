---
layout: base.njk
title: سلة المشتريات
css:
  - /assets/css/cart.css
---

<section class="cart-page">

  <h1 class="cart-title">سلة المشتريات</h1>

  <div class="cart-layout">

    <!-- المنتجات -->
    <div class="cart-items" id="cart-items"></div>

    <!-- ملخص الطلب -->
    <aside class="cart-summary">

      <h3>ملخص الطلب</h3>

      <div class="summary-line">
        <span>المجموع الفرعي</span>
        <strong><span id="cart-subtotal">0</span> درهم</strong>
      </div>

      <div class="summary-line">
        <span>التوصيل</span>
        <strong><span id="shipping-cost">0</span> درهم</strong>
      </div>

      <div class="summary-line total">
        <span>الإجمالي</span>
        <strong><span id="cart-total">0</span> درهم</strong>
      </div>

      <button class="whatsapp-btn" onclick="confirmOrder()">
        اطلب عبر واتساب
      </button>

      <button class="danger-btn" onclick="clearCart()">
        تفريغ السلة
      </button>

    </aside>

  </div>

</section>
<script>
function confirmOrder() {
  const cart = getCart();
  if (!cart || cart.length === 0) {
    alert("السلة فارغة");
    return;
  }

  // رقم واتساب (ممكن تكتبيه كيف بغيتي وهو ينقّيه)
  let phoneRaw = "+212 763-538294";
  let phone = phoneRaw.replace(/[^\d]/g, ""); // يحذف + و المسافات و -

  // رسالة الطلب
  let msg = "🛒 طلب جديد:%0A";
  cart.forEach(item => {
    msg += `- ${item.name} × ${item.qty} = ${item.price * item.qty} درهم%0A`;
  });

  // الحساب
  let total = cart.reduce((s, it) => s + it.price * it.qty, 0);
  let shipping = total >= 600 ? 0 : 40;
  let finalTotal = total + shipping;

  msg += `%0Aالمجموع الفرعي: ${total} درهم%0A`;
  msg += `التوصيل: ${shipping} درهم%0A`;
  msg += `الإجمالي: ${finalTotal} درهم%0A`;

  // فتح واتساب
  const url = `https://wa.me/${phone}?text=${msg}`;
  window.open(url, "_blank");
}
</script>