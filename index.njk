---

<section class="hero">
  <div class="hero-content">
    <h1>عسل طبيعي<br><span>من قلب سوس</span></h1>
    <p>
      نقدم لكم أجود أنواع العسل والمنتوجات <br>الطبيعية
      من تعاونيتنا بجودة <br>عالية وأصالة مغربية.
    </p>

    <div class="hero-buttons">
      <a href="/products/" class="btn btn-primary">منتجاتنا</a>
      <a href="/packs/" class="btn btn-secondary">باقاتنا</a>
    </div>
  </div>
</section>


  <!-- النحلات -->

  <img src="assets/images/bee-v2.png" class="bee bee-1">
  <img src="assets/images/bee-v2.png" class="bee bee-2">
  <img src="assets/images/bee-v2.png" class="bee bee-3">
</section>


<section class="honey-types">

  <div class="section-header">
    <h2>أنواع العسل الطبيعي وفوائده الصحية</h2>
<p class="center-paragraph">
  نوفّر لكم تشكيلة مختارة من أجود أنواع العسل المغربي الأصيل،
  مستخرج بعناية من مناحل طبيعية لضمان الجودة والنقاء.
</p>
    <div class="scroll-hint">
  ← اسحب لاكتشاف الأنواع   →
</div>
  </div>
<div class="honey-scroll-wrapper">



<div class="honey-grid">

{% for product in products %}
  {% if product.id.startsWith("honey-") %}

    <div class="honey-card">
      <div class="hexagon">
        <img src="{{ product.image }}" alt="{{ product.name }}">
      </div>

      <h3>{{ product.name }}</h3>

      <p class="honey-desc">
        {{ product.description }}
      </p>

      <a href="/products/{{ product.id }}/" class="btn-honey">
        اقرأ المزيد
      </a>
    </div>

  {% endif %}
{% endfor %}

</div>



   </div>
</section>
<section class="product-categories">

  <div class="section-header">
    <h2>أنواع المنتوجات التي نقدمها</h2>
  </div>

  <div class="categories-grid">

    <!-- العسل -->
    <div class="category-card">
      <img src="/assets/images/category-honey.png" alt="العسل الطبيعي">
      <div class="category-overlay">
        <h3>العسل الطبيعي</h3>
        <p>أنواع مختلفة من العسل البلدي وفوائده الصحية.</p>
        <a href="/products/?category=honey" class="category-btn">اكتشف العسل</a>
      </div>
    </div>

    <!-- زيت أركان -->
    <div class="category-card">
      <img src="/assets/images/category-argan.png" alt="زيت أركان">
      <div class="category-overlay">
        <h3>زيت أركان</h3>
        <p>زيت أركان أصلي للتجميل والاستعمال الغذائي.</p>
        <a href="/products/?category=argan" class="category-btn">اكتشف زيت أركان</a>
      </div>
    </div>

    <!-- أملو -->
    <div class="category-card">
      <img src="/assets/images/category-amlo.png" alt="أملو بلدي">
      <div class="category-overlay">
        <h3>أملو بلدي</h3>
        <p>أملو تقليدي غني بالطاقة ومكوّنات طبيعية.</p>
        <a href="/products/?category=amlo" class="category-btn">اكتشف أملو</a>
      </div>
    </div>

    <!-- أخرى -->
    <div class="category-card">
      <img src="/assets/images/category-others.png" alt="منتوجات أخرى">
      <div class="category-overlay">
        <h3>منتوجات أخرى</h3>
        <p>منتوجات طبيعية مختارة بعناية من تعاونيتنا.</p>
        <a href="/products/?category=others" class="category-btn">تصفح الكل</a>
      </div>
    </div>

  </div>
</section>

