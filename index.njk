---
layout: base.njk
title: الرئيسية | تعاونية عسب
css:
  - /assets/css/home.css
---

<section class="hero">
  <div class="hero-image">
    <img src="{{ '/assets/images/honey.png' | url }}" alt="عسل طبيعي">
  </div>

  <div class="hero-content">
    <h1>عسل طبيعي<br><span>من قلب سوس</span></h1>
    <p>
      نقدم لكم أجود أنواع العسل والمنتوجات <br>الطبيعية
      من تعاونيتنا بجودة <br>عالية وأصالة مغربية.
    </p>

    <div class="hero-buttons">
      <a href="{{ '/products/' | url }}" class="btn btn-primary">منتجاتنا</a>
      <a href="{{ '/packages/' | url }}" class="btn btn-secondary">باقاتنا</a>
    </div>
  </div>
</section>

<!-- النحل -->
<img src="{{ '/assets/images/bee-v2.png' | url }}" class="bee bee-1">
<img src="{{ '/assets/images/bee-v2.png' | url }}" class="bee bee-2">
<img src="{{ '/assets/images/bee-v2.png' | url }}" class="bee bee-3">

<section class="honey-types">
  <div class="section-header">
    <h2>أنواع العسل الطبيعي وفوائده الصحية</h2>
    <p>
      نوفّر لكم تشكيلة مختارة من أجود أنواع العسل المغربي الأصيل،
      مستخرج بعناية من مناحل طبيعية لضمان الجودة والنقاء.
    </p>
  </div>

  <div class="honey-grid">

  {% for product in products %}
    {% if product.id.startsWith("honey-") %}

      <div class="honey-card">
        <div class="hexagon">
          <img src="{{ product.image | url }}" alt="{{ product.name }}">
        </div>

        <h3>{{ product.name }}</h3>
        <p class="honey-desc">{{ product.description }}</p>

        <a href="{{ ('/products/' + product.id + '/') | url }}" class="btn-honey">
          اقرأ المزيد
        </a>
      </div>

    {% endif %}
  {% endfor %}

  </div>
</section>

<section class="product-categories">
  <div class="categories-grid">

    <div class="category-card">
      <img src="{{ '/assets/images/category-honey.png' | url }}" alt="">
      <a href="{{ '/products/?category=honey' | url }}">اكتشف العسل</a>
    </div>

    <div class="category-card">
      <img src="{{ '/assets/images/category-argan.png' | url }}" alt="">
      <a href="{{ '/products/?category=argan' | url }}">اكتشف زيت أركان</a>
    </div>

    <div class="category-card">
      <img src="{{ '/assets/images/category-amlo.png' | url }}" alt="">
      <a href="{{ '/products/?category=amlo' | url }}">اكتشف أملو</a>
    </div>

    <div class="category-card">
      <img src="{{ '/assets/images/category-others.png' | url }}" alt="">
      <a href="{{ '/products/?category=others' | url }}">تصفح الكل</a>
    </div>

  </div>
</section>

<section class="home-packages">
  <div class="packages-grid">

    <div class="package-card-home">
      <img src="{{ '/assets/images/package-1.jpg' | url }}" alt="">
      <a href="{{ '/packages/' | url }}">عرض التفاصيل</a>
    </div>

    <div class="package-card-home">
      <img src="{{ '/assets/images/package-2.jpg' | url }}" alt="">
      <a href="{{ '/packages/' | url }}">عرض التفاصيل</a>
    </div>

    <div class="package-card-home">
      <img src="{{ '/assets/images/package-3.jpg' | url }}" alt="">
      <a href="{{ '/packages/' | url }}">عرض التفاصيل</a>
    </div>

  </div>
</section>

<section class="cta-section">
  <div class="cta-content">
    <h2>اطلب عسلك الطبيعي الآن</h2>

    <div class="cta-buttons">
      <a href="{{ '/products/' | url }}" class="cta-btn primary">
        تصفح المنتجات
      </a>

      <a href="https://wa.me/212770898635" class="cta-btn secondary">
        تواصل عبر واتساب
      </a>
    </div>
  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const bees = document.querySelectorAll(".bee");
  bees.forEach((bee, index) => {
    setTimeout(() => {
      bee.classList.add("fly");
    }, index * 700);
  });

});
</script>
