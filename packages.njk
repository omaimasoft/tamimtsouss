css:
  - /assets/css/packages.css
packages:
  - name: "باقة 1"
    badge: "عرض مميز"
    image: "/assets/images/package-1.png"
    price: 550
    desc: "باقة متكاملة تضم أفضل أنواع العسل المغربي الطبيعي مع أملو وزعفران."
    items:
      - "1 كيلو عسل ليمون"
      - "1 كيلو عسل خروب"
      - "1 كيلو عسل الأوكاليبتوس"
      - "1 كيلو أملو"
      - "زعفران × 2"

  - name: "باقة 2"
    image: "/assets/images/package-2.png"
    price: 550
    desc: "تشكيلة غنية من العسل الطبيعي المغربي مع أملو عالي الجودة."
    items:
      - "1 كيلو عسل ليمون"
      - "1 كيلو عسل خروب"
      - "1 كيلو عسل الدغموس"
      - "1 كيلو أملو"

  - name: "باقة 3"
    image: "/assets/images/package-3.png"
    price: 520
    desc: "باقة اقتصادية تضم تشكيلة عسل طبيعية مع أملو مغربي أصيل."
    items:
      - "1 كيلو عسل ليمون"
      - "1 كيلو عسل خروب"
      - "1 كيلو عسل الأعشاب"
      - "1 كيلو أملو"

  - name: "باقة 4"
    image: "/assets/images/package-4.png"
    price: 575
    desc: "باقة فاخرة تضم أربعة أنواع مميزة من العسل المغربي الطبيعي."
    items:
      - "1 كيلو عسل ليمون"
      - "1 كيلو عسل الأعشاب"
      - "1 كيلو عسل الأوكاليبتوس"
      - "1 كيلو عسل الزعتر"
---

<section class="packages-hero">
  <h1>باقاتنا</h1>
  <p>اختاري الباقة اللي كتناسبك، وطلبي مباشرة عبر واتساب.</p>
</section>

<section class="packages-section">
  {% for p in packages %}
  <article class="package-card {% if p.badge %}featured{% endif %}">
    {% if p.badge %}
      <span class="badge">{{ p.badge }}</span>
    {% endif %}

    <div class="package-image">
      <img
        src="{{ p.image | url }}"
        alt="{{ p.name }}"
        loading="lazy"
        decoding="async"
      >
    </div>

    <h2>{{ p.name }}</h2>
    <p class="package-desc">{{ p.desc }}</p>

    <ul class="package-features">
      {% for it in p.items %}
      <li>{{ it }}</li>
      {% endfor %}
    </ul>

    <div class="package-bottom">
      <div class="package-price">{{ p.price }} درهم</div>

      <!-- زر واتساب -->
      <a
        class="package-btn wa-btn"
        target="_blank"
        rel="noopener"
        data-name="{{ p.name }}"
        data-price="{{ p.price }}"
        data-items="{{ p.items | join(' | ') }}"
      >
        اطلب عبر واتساب
      </a>
    </div>
  </article>
  {% endfor %}
</section>

<script>
  // ✅ رقم واتساب بصيغة دولية (بدون 0)
  const WA_NUMBER = "212763538294";

  document.querySelectorAll(".wa-btn").forEach(btn => {
    const name  = btn.dataset.name;
    const price = btn.dataset.price;
    const items = (btn.dataset.items || "").split(" | ").filter(Boolean);

    const itemsText = items.map(i => `- ${i}`).join("\n");

    const msg =
`سلام عليكم 👋
بغيت نطلب: ${name}
الثمن: ${price} درهم

المحتوى:
${itemsText}

الاسم:
المدينة:
العنوان:
شكراً لكم ✅`;

    btn.href = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`;
  });
</script>